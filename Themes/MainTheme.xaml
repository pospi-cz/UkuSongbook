<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ════════════════════════════════════════════════════════════
     MainTheme.xaml — komponenty a styly
     Všechny barvy přes DynamicResource → reagují na přepnutí tématu
     Font: Segoe UI Variable (Win11 systémový font)
     Rohy: 4px tlačítka / 6px listy a inputy / 8px karty (Fluent 2)
    ════════════════════════════════════════════════════════════
    -->

    <FontFamily x:Key="Win11Font">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>

    <!-- ── Icon Button ──────────────────────────────────────── -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Padding"          Value="7,5"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Foreground"       Value="{DynamicResource ToolbarIconBrush}"/>
        <Setter Property="FontFamily"       Value="{StaticResource Win11Font}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource SidebarHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource SidebarSelectedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Primary / Accent Button (Filled) ────────────────── -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource PrimaryForegroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="16,6"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontFamily"      Value="{StaticResource Win11Font}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="MinHeight"       Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource PrimaryHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource PrimaryPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Secondary Button (Subtle/Outlined) ───────────────── -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="16,6"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontFamily"      Value="{StaticResource Win11Font}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="MinHeight"       Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource SidebarHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource SidebarSelectedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Song List Item — NavigationView styl ────────────── -->
    <!--
         Win11 NavigationViewItem:
         - hover:    ControlFillColorSecondary (velmi průhledný)
         - selected: AccentFillColorSelectedTextBackground (#0067C014 / #60CDFF1A)
         - accent bar 3px vlevo zaoblený
    -->
    <Style x:Key="SongListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background"    Value="Transparent"/>
        <Setter Property="Foreground"    Value="{DynamicResource SidebarTextBrush}"/>
        <Setter Property="Padding"       Value="0"/>
        <Setter Property="Margin"        Value="4,1"/>
        <Setter Property="Cursor"        Value="Hand"/>
        <Setter Property="FontFamily"    Value="{StaticResource Win11Font}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <!-- Accent bar — viditelný jen při IsSelected -->
                        <Rectangle x:Name="accentBar"
                                   Width="3" HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Height="16" RadiusX="1.5" RadiusY="1.5"
                                   Margin="0" Panel.ZIndex="1"
                                   Fill="{DynamicResource SidebarAccentBarBrush}"
                                   Visibility="Collapsed"/>
                        <!-- Hlavní pozadí položky -->
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="10,7"
                                Margin="0,0,0,0">
                            <ContentPresenter/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource SidebarHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource SidebarSelectedBrush}"/>
                            <Setter TargetName="accentBar" Property="Visibility"
                                    Value="Visible"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource SidebarSelectedTextBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource SidebarSelectedBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Search TextBox (barvy z LightTheme / DarkTheme: SearchBox*Brush) ── -->
    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background"        Value="{DynamicResource SearchBoxBackgroundBrush}"/>
        <Setter Property="Foreground"        Value="{DynamicResource SearchBoxForegroundBrush}"/>
        <Setter Property="BorderBrush"       Value="{DynamicResource SearchBoxBorderBrush}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="Padding"           Value="10,7"/>
        <Setter Property="FontSize"          Value="13"/>
        <Setter Property="FontFamily"        Value="{StaticResource Win11Font}"/>
        <Setter Property="CaretBrush"        Value="{DynamicResource SearchBoxForegroundBrush}"/>
        <Setter Property="SelectionBrush"    Value="{DynamicResource SearchBoxSelectionBrush}"/>
        <Setter Property="SelectionOpacity"  Value="1"/>
        <Setter Property="MinHeight"         Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="outerBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"/>
                        <!-- Focus accent line dole (Win11 styl) -->
                        <Border x:Name="focusLine"
                                Height="2" VerticalAlignment="Bottom"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource SearchBoxFocusBrush}"
                                CornerRadius="0,0,4,4"
                                Opacity="0"/>
                        <Border Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="focusLine" Property="Opacity" Value="1"/>
                            <Setter TargetName="outerBorder" Property="BorderBrush"
                                    Value="{DynamicResource SearchBoxBorderBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Sidebar ComboBox — položky rozbalovacího seznamu (stejné barvy jako SearchBox) ── -->
    <Style x:Key="SidebarComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource SearchBoxForegroundBrush}"/>
        <Setter Property="Padding"    Value="10,6"/>
        <Setter Property="FontFamily" Value="{StaticResource Win11Font}"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource SidebarHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource SidebarSelectedBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource SidebarSelectedTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Sidebar ComboBox — vzhled jako SearchBoxStyle (rámeček, spodní linka focus/otevření) ── -->
    <Style x:Key="SidebarComboStyle" TargetType="ComboBox">
        <Setter Property="Background"                  Value="Transparent"/>
        <Setter Property="Foreground"                  Value="{DynamicResource SearchBoxForegroundBrush}"/>
        <Setter Property="BorderThickness"             Value="0"/>
        <Setter Property="Padding"                     Value="10,7"/>
        <Setter Property="FontSize"                     Value="13"/>
        <Setter Property="FontFamily"                  Value="{StaticResource Win11Font}"/>
        <Setter Property="MinHeight"                   Value="32"/>
        <Setter Property="FocusVisualStyle"            Value="{x:Null}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"     Value="Center"/>
        <Setter Property="ItemContainerStyle"         Value="{StaticResource SidebarComboBoxItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" MinWidth="28"/>
                        </Grid.ColumnDefinitions>

                        <Popup x:Name="PART_Popup"
                               Grid.ColumnSpan="2"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    Background="{DynamicResource SearchBoxBackgroundBrush}"
                                    BorderBrush="{DynamicResource SearchBoxBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,2,0,0"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{Binding ActualWidth, ElementName=MainGrid}"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer Margin="0,4"
                                              Padding="0,0,4,0"
                                              SnapsToDevicePixels="True"
                                              HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                              VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>

                        <Border x:Name="OuterBorder"
                                Grid.ColumnSpan="2"
                                Background="{DynamicResource SearchBoxBackgroundBrush}"
                                BorderBrush="{DynamicResource SearchBoxBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinHeight="{TemplateBinding MinHeight}"/>
                        <Border x:Name="FocusLine"
                                Grid.ColumnSpan="2"
                                Height="2"
                                VerticalAlignment="Bottom"
                                Background="{DynamicResource SearchBoxFocusBrush}"
                                CornerRadius="0,0,4,4"
                                Opacity="0"/>
                        <ToggleButton x:Name="DropDownToggle"
                                      Grid.ColumnSpan="2"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ClickMode="Press"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Grid.Column="0"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          IsHitTestVisible="False"
                                          SnapsToDevicePixels="True"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          TextElement.Foreground="{DynamicResource SearchBoxForegroundBrush}"/>
                        <Path Grid.Column="1"
                              Margin="0,0,10,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="{DynamicResource SearchBoxForegroundBrush}"
                              IsHitTestVisible="False"
                              Stretch="Uniform"
                              Width="6"
                              Height="4"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FocusLine" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="FocusLine" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Editor (VS Code / tmavý) ────────────────────────── -->
    <Style x:Key="EditorStyle" TargetType="TextBox">
        <Setter Property="Background"                  Value="{DynamicResource EditorBgBrush}"/>
        <Setter Property="Foreground"                  Value="{DynamicResource EditorFgBrush}"/>
        <Setter Property="BorderThickness"             Value="0"/>
        <Setter Property="Padding"                     Value="16"/>
        <Setter Property="FontFamily"                  Value="Cascadia Code, Consolas, Courier New"/>
        <Setter Property="FontSize"                    Value="13"/>
        <Setter Property="AcceptsReturn"               Value="True"/>
        <Setter Property="AcceptsTab"                  Value="True"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="CaretBrush"                  Value="#AEAFAD"/>
        <Setter Property="SelectionBrush"              Value="#264F78"/>
    </Style>

    <!-- ── Toolbar Separator ────────────────────────────────── -->
    <Style x:Key="ToolbarSeparatorStyle" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource ToolbarBorderBrush}"/>
        <Setter Property="Width"      Value="1"/>
        <Setter Property="Margin"     Value="6,6"/>
    </Style>

</ResourceDictionary>
