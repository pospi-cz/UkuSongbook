<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ════════════════════════════════════════════════════════════
     LIGHT THEME — přesné hodnoty z WinUI 3 / Fluent Design
     Zdroj: microsoft-ui-xaml themeresources + Fluent 2 tokens
    ════════════════════════════════════════════════════════════

     Vrstvy pozadí (světlé = světlejší jsou výše):
       SolidBackgroundFillColorBase        #F3F3F3   (hlavní okno)
       SolidBackgroundFillColorSecondary   #EEEEEE   (sidebar/panel)
       SolidBackgroundFillColorTertiary    #F9F9F9   (karta/toolbar)
       SolidBackgroundFillColorQuarternary #FFFFFF   (vstupní pole)

     Vrstvy vrstvení (Layer):
       LayerFillColorDefault               rgba(255,255,255,0.5)  → #FFFFFF80
       LayerFillColorAlt                   #FFFFFF

     Texty:
       TextFillColorPrimary                rgba(0,0,0,0.8956)   → #000000E4
       TextFillColorSecondary              rgba(0,0,0,0.6063)   → #0000009B
       TextFillColorDisabled               rgba(0,0,0,0.3614)   → #0000005C

     Accent (výchozí Win11 modrá):
       AccentDefault                       #0067C0
       AccentLight1                        #1975CF
       AccentDark1                         #005BA4

     Ovládací prvky:
       ControlFillColorDefault             rgba(255,255,255,0.70) → #FFFFFFB3
       ControlFillColorSecondary           rgba(249,249,249,0.50) → #F9F9F980
       ControlFillColorTertiary            rgba(249,249,249,0.30) → #F9F9F94D
       ControlStrokeColorDefault           rgba(0,0,0,0.0578)    → #0000000F
       ControlStrokeColorSecondary         rgba(0,0,0,0.1614)    → #00000029
    -->

    <!-- ── Hlavní pozadí ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppBackgroundBrush"        Color="#F3F3F3"/>
    <SolidColorBrush x:Key="AppForegroundBrush"        Color="#1A1A1A"/>

    <!-- ── Sidebar / NavigationView ─────────────────────────── -->
    <SolidColorBrush x:Key="SidebarBrush"              Color="#EEEEEE"/>
    <SolidColorBrush x:Key="SidebarHeaderBrush"        Color="#E8E8E8"/>
    <SolidColorBrush x:Key="SidebarTextBrush"          Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"         Color="#00000009"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush"      Color="#0067C014"/>
    <SolidColorBrush x:Key="SidebarSelectedTextBrush"  Color="#003E92"/>
    <SolidColorBrush x:Key="SidebarAccentBarBrush"     Color="#0067C0"/>
    <SolidColorBrush x:Key="SidebarInputBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarSubtextBrush"       Color="#5D5D5D"/>
    <SolidColorBrush x:Key="SidebarMutedBrush"         Color="#9D9D9D"/>
    <SolidColorBrush x:Key="SidebarSeparatorBrush"     Color="#0000000F"/>

    <!-- ── Toolbar ───────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ToolbarBrush"              Color="#F9F9F9"/>
    <SolidColorBrush x:Key="ToolbarBorderBrush"        Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ToolbarTextBrush"          Color="#5D5D5D"/>
    <SolidColorBrush x:Key="ToolbarIconBrush"          Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ToolbarPillBrush"          Color="#0000000A"/>

    <!-- ── Status bar ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="StatusBarBrush"            Color="#F3F3F3"/>
    <SolidColorBrush x:Key="StatusBarBorderBrush"      Color="#E0E0E0"/>
    <SolidColorBrush x:Key="StatusBarTextBrush"        Color="#7A7A7A"/>
    <SolidColorBrush x:Key="StatusBarMutedBrush"       Color="#ABABAB"/>

    <!-- ── Accent ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PrimaryBrush"              Color="#0067C0"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"         Color="#1975CF"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush"       Color="#005BA4"/>
    <SolidColorBrush x:Key="PrimaryForegroundBrush"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DangerBrush"               Color="#C42B1C"/>
    <SolidColorBrush x:Key="DangerHoverBrush"          Color="#B5220E"/>

    <!-- ── Borders / Cards / Text ────────────────────────────── -->
    <SolidColorBrush x:Key="SplitterBrush"             Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BorderBrush"               Color="#E0E0E0"/>
    <SolidColorBrush x:Key="CardBrush"                 Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"          Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"        Color="#5D5D5D"/>

    <!-- ── Vstupní pole ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="InputBorderBrush"          Color="#00000029"/>
    <SolidColorBrush x:Key="InputBorderFocusBrush"     Color="#0067C0"/>
    <SolidColorBrush x:Key="InputBgBrush"              Color="#FFFFFF"/>

    <!-- ── Vyhledávací pole (sidebar) ───────────────────────── -->
    <SolidColorBrush x:Key="SearchBoxBackgroundBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SearchBoxBorderBrush"       Color="#00000029"/>
    <SolidColorBrush x:Key="SearchBoxForegroundBrush"   Color="#1A1A1A"/>
    <SolidColorBrush x:Key="SearchBoxPlaceholderBrush" Color="#9D9D9D"/>
    <SolidColorBrush x:Key="SearchBoxFocusBrush"      Color="#0067C0"/>
    <SolidColorBrush x:Key="SearchBoxSelectionBrush"   Color="#CCE8FF"/>

    <!-- ── Editor (vždy tmavý) ──────────────────────────────── -->
    <SolidColorBrush x:Key="EditorBgBrush"             Color="#1E1E1E"/>
    <SolidColorBrush x:Key="EditorFgBrush"             Color="#D4D4D4"/>
    <SolidColorBrush x:Key="EditorHeaderBrush"         Color="#252526"/>
    <SolidColorBrush x:Key="EditorHeaderTextBrush"     Color="#858585"/>

    <!-- ── Menu ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="MenuBackgroundBrush"       Color="#F3F3F3"/>
    <SolidColorBrush x:Key="MenuForegroundBrush"       Color="#1A1A1A"/>
    <SolidColorBrush x:Key="MenuItemHoverBrush"        Color="#00000009"/>
    <SolidColorBrush x:Key="MenuBorderBrush"           Color="#E0E0E0"/>

</ResourceDictionary>
